{
  "name": "@zoneless/source",
  "version": "0.1.0",
  "description": "Open-source Stripe Connect alternative using USDC on Solana",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/zonelessdev/zoneless.git"
  },
  "homepage": "https://zoneless.com",
  "bugs": {
    "url": "https://github.com/zonelessdev/zoneless/issues"
  },
  "scripts": {
    "kill": "./scripts/kill-all.sh",
    "dev": "docker compose up mongodb mongo-express -d && nx run-many -t serve -p api web --output-style=stream",
    "start:api": "nx serve api",
    "start:web": "nx serve web",
    "start:db": "docker compose up mongodb mongo-express -d",
    "prod": "docker compose --env-file .env.production up -d --build",
    "stop:db": "docker compose down",
    "build:api": "nx build api && cd dist/apps/api && npm install --package-lock-only",
    "build:web": "nx build web --configuration=production",
    "format": "prettier --write \"**/*.{ts,html,scss,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,html,scss,json,md}\"",
    "lint": "npx nx run-many --target=lint --all",
    "test": "npx nx run-many --target=test --all"
  },
  "private": true,
  "devDependencies": {
    "@angular-devkit/core": "~20.3.0",
    "@angular-devkit/schematics": "~20.3.0",
    "@angular/build": "~20.3.0",
    "@angular/cli": "~20.3.0",
    "@angular/compiler-cli": "~20.3.0",
    "@angular/language-service": "~20.3.0",
    "@eslint/js": "^9.8.0",
    "@nx/angular": "^22.2.0",
    "@nx/eslint": "22.2.0",
    "@nx/eslint-plugin": "22.2.0",
    "@nx/express": "^22.2.0",
    "@nx/jest": "22.2.0",
    "@nx/js": "22.2.0",
    "@nx/node": "^22.2.0",
    "@nx/web": "22.2.0",
    "@nx/webpack": "22.2.0",
    "@nx/workspace": "22.2.0",
    "@schematics/angular": "~20.3.0",
    "@swc-node/register": "~1.9.1",
    "@swc/core": "~1.5.7",
    "@swc/helpers": "~0.5.11",
    "@types/bs58": "^4.0.4",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "20.19.9",
    "@typescript-eslint/utils": "^8.40.0",
    "angular-eslint": "^20.3.0",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-preset-angular": "~14.6.1",
    "jest-util": "^29.7.0",
    "jsonc-eslint-parser": "^2.1.0",
    "nx": "22.2.0",
    "prettier": "^2.6.2",
    "ts-jest": "^29.1.0",
    "ts-node": "10.9.1",
    "tslib": "^2.3.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@angular/common": "~20.3.0",
    "@angular/compiler": "~20.3.0",
    "@angular/core": "~20.3.0",
    "@angular/forms": "~20.3.0",
    "@angular/platform-browser": "~20.3.0",
    "@angular/platform-browser-dynamic": "~20.3.0",
    "@angular/router": "~20.3.0",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "axios": "^1.6.0",
    "bs58": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.0.1",
    "rxjs": "~7.8.0",
    "zod": "^4.1.13"
  }
}
